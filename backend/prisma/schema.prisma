// Prisma schema pour ktOptima
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
//  ORGANIZATION — Tenant/Client pour le multitenant
// ═══════════════════════════════════════════════════════════════
model Organization {
  id          String   @id @default(cuid())
  name        String   // ex: "Bilan Tunisie"
  email       String?  // Email de contact de l'organisation
  phone       String?
  address     String?
  tva         String?  // Numéro TVA
  logoUrl     String?  // URL du logo
  paymentStatus String @default("PENDING") // PENDING, APPROVED, REJECTED
  suspended   Boolean  @default(false)
  plan        String   @default("FREE") // FREE, BUSINESS, ENTERPRISE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  clients     Client[]
  leads       Lead[]
  affaires    Affaire[]
  products    Product[]
  activites   Activite[]
  leadActivites LeadActivite[]
  calendarEvents CalendarEvent[]
  expenses    Expense[]
  emails      Email[]
  gmailTokens GmailToken[]
  previsionnels PrevisionMois[]
  notifications Notification[]
  auditLogs   AuditLog[]
  customCategories CustomCategory[]
  emailTemplates EmailTemplate[]
  subscriptions Subscription[]
  salesObjectives SalesObjective[]
  userPermissions UserPermission[]
  commissionConfig CommissionConfig?

  @@map("organizations")
}

// ═══════════════════════════════════════════════════════════════
//  USER — Utilisateur du CRM
// ═══════════════════════════════════════════════════════════════
model User {
  id           String   @id @default(cuid())
  organizationId String
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         UserRole @default(OWNER)
  failedLoginAttempts Int @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientsCreated   Client[]
  leadsCreated     Lead[]
  affairesCreated  Affaire[]
  assignedAffaires Affaire[] @relation("CommercialAffaires")
  calendarEventsCreated CalendarEvent[]
  expensesCreated  Expense[]
  gmailTokens      GmailToken?
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  salesObjectives  SalesObjective[]
  permissions      UserPermission[]

  @@index([organizationId])
  @@map("users")
}

enum UserRole {
  OWNER       // Accès complet, gestion des utilisateurs
  PARTNER     // Accès limité, lecture seule sur les données
  COMMERCIAL  // Accès limité aux opportunités assignées, objectifs
  SUPERADMIN  // Super admin pour valider les paiements
}

// ═══════════════════════════════════════════════════════════════
//  CLIENT — Entreprises clientes
// ═══════════════════════════════════════════════════════════════
model Client {
  id          String   @id @default(cuid())
  organizationId String
  name        String   // ex: "UBCI"
  contactName String?  // ex: "Ahmed Ben Ali"
  email       String?
  phone       String?
  address     String?
  matricule   String?  // Matricule fiscal tunisien
  qualificatif String?  // ex: "PROSPECT" ou "CLIENT"
  notes       String?  @db.Text
  deletedAt   DateTime? // Soft delete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id])
  affaires    Affaire[]
  leads       Lead[]    @relation("ClientLeads")
  convertedFromLeads Lead[] @relation("LeadConversions")

  @@index([organizationId])
  @@index([name])
  @@index([deletedAt])
  @@map("clients")
}

// ═══════════════════════════════════════════════════════════════
//  LEAD — Prospects avant conversion en client/affaire
// ═══════════════════════════════════════════════════════════════
model Lead {
  id            String   @id @default(cuid())
  organizationId String
  clientId      String?
  client        Client?    @relation("ClientLeads", fields: [clientId], references: [id])
  name          String   // Nom de l'entreprise ou du prospect
  contactName   String?  // Nom du contact
  email         String?
  phone         String?
  company       String?  // Entreprise (si différent du nom principal)
  source        LeadSource @default(AUTRE) // Origine du lead
  status        LeadStatus @default(NEW) // État du lead
  score         Int      @default(0) // Score de qualification (0-100)
  estimatedValue Decimal? @db.Decimal(12, 3) // Valeur estimée DT
  notes         String?  @db.Text
  convertedToClientId String?
  convertedToClient Client?  @relation("LeadConversions", fields: [convertedToClientId], references: [id])
  deletedAt     DateTime? // Soft delete
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id])

  // Relations
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activites     LeadActivite[]
  calendarEvents CalendarEvent[]
  expenses      Expense[]

  @@index([organizationId])
  @@index([status])
  @@index([score])
  @@index([deletedAt])
  @@map("leads")
}

enum LeadSource {
  WEBSITE
  REFERRAL
  LINKEDIN
  EMAIL
  PHONE
  EVENT
  PARTNER
  AUTRE
}

enum LeadStatus {
  NEW        // Nouveau prospect
  CONTACTED  // Premier contact établi
  QUALIFIED  // Qualifié, prêt pour conversion
  CONVERTED  // Converti en client
  LOST       // Perdu
}

// ═══════════════════════════════════════════════════════════════
//  CALENDAR EVENT — Événements du calendrier
// ═══════════════════════════════════════════════════════════════
model CalendarEvent {
  id            String   @id @default(cuid())
  organizationId String
  title         String
  description   String?  @db.Text
  startDate     DateTime
  endDate       DateTime
  allDay        Boolean  @default(false)
  eventType     EventType @default(MEETING)
  location      String?
  relatedAffaireId String?
  relatedAffaire Affaire? @relation(fields: [relatedAffaireId], references: [id], onDelete: SetNull)
  relatedLeadId String?
  relatedLead   Lead?    @relation(fields: [relatedLeadId], references: [id], onDelete: SetNull)
  status        EventStatus @default(SCHEDULED)
  reminderMinutes Int?   // Minutes avant l'événement pour le rappel
  deletedAt     DateTime? // Soft delete
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id])

  // Relations
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([startDate])
  @@index([eventType])
  @@index([deletedAt])
  @@map("calendar_events")
}

enum EventType {
  MEETING
  CALL
  TASK
  REMINDER
  DEADLINE
  AUTRE
}

enum EventStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  POSTPONED
}

// ═══════════════════════════════════════════════════════════════
//  EXPENSE — Dépense
// ═══════════════════════════════════════════════════════════════
model Expense {
  id            String   @id @default(cuid())
  organizationId String
  title         String
  description   String?  @db.Text
  amount        Decimal  @db.Decimal(12, 3) // DT
  currency      String   @default("TND")
  category      String   @default("Autre")
  date          DateTime @default(now())
  relatedAffaireId String?
  relatedAffaire Affaire? @relation(fields: [relatedAffaireId], references: [id], onDelete: SetNull)
  relatedLeadId String?
  relatedLead   Lead?    @relation(fields: [relatedLeadId], references: [id], onDelete: SetNull)
  status        ExpenseStatus @default(PENDING)
  receiptUrl    String?  // URL du justificatif
  isRecurrent   Boolean  @default(false)
  recurrenceMonths String?  // e.g., "1,2,3" for months to repeat
  notes         String?  @db.Text
  deletedAt     DateTime? // Soft delete
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id])

  // Relations
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([date])
  @@index([category])
  @@index([status])
  @@index([deletedAt])
  @@map("expenses")
}

enum ExpenseCategory {
  OPERATIONAL // Frais opérationnels
  TRAVEL // Déplacements
  MEAL // Repas
  ACCOMMODATION // Hébergement
  EQUIPMENT // Matériel
  SOFTWARE // Logiciels
  MARKETING // Marketing
  COMMISSION // Commissions
  OTHER // Autre
}

// ═══════════════════════════════════════════════════════════════
//  CUSTOM CATEGORY — Catégories personnalisées (dépenses/revenus)
// ═══════════════════════════════════════════════════════════════
model CustomCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           CategoryType
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name, type])
  @@index([organizationId, type])
  @@map("custom_categories")
}

enum CategoryType {
  EXPENSE
  REVENUE
}

enum ExpenseStatus {
  PENDING // En attente
  APPROVED // Approuvé
  REJECTED // Rejeté
  PAID // Payé
}

// ═══════════════════════════════════════════════════════════════
//  AFFAIRE — Deal / Opportunité (cœur du CRM)
// ═══════════════════════════════════════════════════════════════
model Affaire {
  id            String        @id @default(cuid())
  organizationId String
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Détails prestation
  productId     String?
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  type          String        @default("Autre")
  title         String?       // ex: "Bilan Carbone UBCI 2026" - auto-généré si non fourni
  description   String?       @db.Text
  montantHT     Decimal       @db.Decimal(12, 3) // DT, 3 décimales

  // Pipeline
  statut        StatutAffaire @default(PROSPECT)
  probabilite   Int           @default(50) // 0-100 %
  score         Int           @default(0) // Lead score 0-100

  // Planning
  moisPrevu     Int           // 1-12
  anneePrevue   Int           // 2026, 2027, 2028
  dateClotureReelle DateTime?
  prochaineAction String?      // ex: "Appeler client", "Envoyer devis"
  dateProchaineAction DateTime?

  // Partenaire & commission
  viaPartenaire Boolean       @default(false)
  tauxCommission Decimal      @db.Decimal(5, 2) @default(40.00) // 40%

  // Commercial assigné
  assignedToId String?
  assignedTo    User?         @relation("CommercialAffaires", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Liens vers Softfacture (quand devis/facture créés)
  devisId       String?       // ID retourné par Softfacture API
  devisNumero   String?
  devisPdfUrl   String?
  factureId     String?
  factureNumero String?
  facturePdfUrl String?

  // Méta
  notes         String?       @db.Text
  deletedAt     DateTime?     // Soft delete
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdById   String?
  createdBy     User?         @relation(fields: [createdById], references: [id])

  // Relations
  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activites     Activite[]
  calendarEvents CalendarEvent[]
  expenses      Expense[]
  emails        Email[]

  @@index([organizationId])
  @@index([statut, anneePrevue])
  @@index([clientId])
  @@index([productId])
  @@index([assignedToId])
  @@index([deletedAt])
  @@map("affaires")
}

// AffaireType is now a free-form String managed via custom categories

enum StatutAffaire {
  PROSPECT     // 🟡 Premier contact
  QUALIFIE     // 🔵 Intérêt confirmé
  PROPOSITION  // � Offre envoyée
  NEGOCIATION  // 🟣 En discussion
  GAGNE        // ✅ Signé
  PERDU        // ❌ Refusé ou abandonné
}

// ═══════════════════════════════════════════════════════════════
//  ACTIVITE — Historique des actions sur une affaire
// ═══════════════════════════════════════════════════════════════
model Activite {
  id        String        @id @default(cuid())
  organizationId String
  affaireId String
  affaire   Affaire       @relation(fields: [affaireId], references: [id], onDelete: Cascade)
  type      ActiviteType
  title     String
  content   String?       @db.Text
  createdAt DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([affaireId, createdAt])
  @@map("activites")
}

// ═══════════════════════════════════════════════════════════════
//  LEAD ACTIVITE — Historique des actions sur un lead
// ═══════════════════════════════════════════════════════════════
model LeadActivite {
  id        String        @id @default(cuid())
  organizationId String
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      ActiviteType
  title     String
  content   String?       @db.Text
  createdAt DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([leadId, createdAt])
  @@map("lead_activites")
}

enum ActiviteType {
  NOTE
  APPEL
  EMAIL_ENVOYE
  EMAIL_RECU
  RDV
  CHANGEMENT_STATUT
  DEVIS_CREE
  FACTURE_CREEE
  AUTRE
}

// ═══════════════════════════════════════════════════════════════
//  EMAIL — Emails envoyés depuis le CRM via Gmail
// ═══════════════════════════════════════════════════════════════
model Email {
  id          String   @id @default(cuid())
  organizationId String
  affaireId   String?
  affaire     Affaire? @relation(fields: [affaireId], references: [id], onDelete: SetNull)
  messageId   String?  // ID Gmail
  fromEmail   String
  toEmail     String
  subject     String
  body        String   @db.Text
  sent        Boolean  @default(false)
  sentAt      DateTime?
  error       String?
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([affaireId])
  @@map("emails")
}

// ═══════════════════════════════════════════════════════════════
//  GMAIL TOKEN — OAuth tokens pour envoi d'emails
// SECURITY: Tokens stored in plain text. In production, consider encryption-at-rest (AES-256)
// ═══════════════════════════════════════════════════════════════
model GmailToken {
  id           String   @id @default(cuid())
  organizationId String
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String   @db.Text // TODO: encrypt at rest
  refreshToken String   @db.Text // TODO: encrypt at rest
  expiresAt    DateTime
  scope        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("gmail_tokens")
}

// ═══════════════════════════════════════════════════════════════
//  PREVISIONNEL — Hypothèses mensuelles paramétrables
// ═══════════════════════════════════════════════════════════════
model PrevisionMois {
  id               String  @id @default(cuid())
  organizationId    String
  annee            Int
  mois             Int     // 1-12
  nbBilansPrevu    Int     @default(0)
  prixMoyenBilan   Decimal @db.Decimal(12, 3) @default(0)
  joursFormation   Int     @default(0)
  tarifJourFormation Decimal @db.Decimal(12, 3) @default(0)
  estEte           Boolean @default(false)
  tauxPartenaire   Decimal @db.Decimal(5, 2) @default(0) // % d'affaires via partenaire
  notes            String?
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@unique([organizationId, annee, mois])
  @@map("prevision_mois")
}

// ═══════════════════════════════════════════════════════════════
//  PRODUCT — Produits/Services proposés
// ═══════════════════════════════════════════════════════════════
model Product {
  id          String   @id @default(cuid())
  organizationId String
  name        String   // ex: "Bilan Carbone Standard"
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 3) // Prix unitaire DT
  type        ProductType @default(SERVICE)
  active      Boolean  @default(true)
  deletedAt   DateTime? // Soft delete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  affaires    Affaire[]

  @@index([organizationId])
  @@index([active])
  @@index([deletedAt])
  @@map("products")
}

// ═══════════════════════════════════════════════════════════════
//  NOTIFICATION — Notifications pour les utilisateurs
// ═══════════════════════════════════════════════════════════════
model Notification {
  id            String   @id @default(cuid())
  organizationId String
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          NotificationType
  title         String
  content       String?  @db.Text
  link          String?  // URL to navigate to when clicked
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId, read])
  @@map("notifications")
}

enum NotificationType {
  AFFAIRE_SANS_ACTIVITE  // Affaire sans activité depuis X jours
  TASK_OVERDUE           // Tâche en retard
  AFFAIRE_PERDUE         // Affaire perdue
  AFFAIRE_GAGNEE         // Affaire gagnée
  DEVIS_CREE             // Devis créé
  FACTURE_CREEE          // Facture créée
  RAPPEL                 // Rappel personnalisé
}

// ═══════════════════════════════════════════════════════════════
//  REFRESH TOKEN — JWT refresh tokens pour authentification persistante
// SECURITY: Token stored in plain text. In production, hash with bcrypt for verification
// ═══════════════════════════════════════════════════════════════
model RefreshToken {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique // TODO: hash with bcrypt for production
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

enum ProductType {
  SERVICE  // Bilan carbone, formation, conseil
  PRODUCT  // Produit physique
}

// ═══════════════════════════════════════════════════════════════
//  AUDIT LOG — Logs d'audit pour traçabilité des actions
// ═══════════════════════════════════════════════════════════════
model AuditLog {
  id            String   @id @default(cuid())
  organizationId String
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action        AuditAction
  entityType    String   // ex: "Client", "Affaire", "User"
  entityId      String   // ID de l'entité concernée
  oldValues     String?  @db.Text // Valeurs avant modification (JSON)
  newValues     String?  @db.Text // Valeurs après modification (JSON)
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
}

// ═══════════════════════════════════════════════════════════════
//  EMAIL TEMPLATE — Templates d'emails personnalisables
// ═══════════════════════════════════════════════════════════════
model EmailTemplate {
  id            String   @id @default(cuid())
  organizationId String
  name          String   // ex: "Suivi devis", "Rappel échéance"
  subject       String   // Sujet avec variables : {client}, {montant}, etc.
  body          String   @db.Text // Corps avec variables
  variables     String   // JSON: ["client", "montant", "date", "statut"]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("email_templates")
}

// ═══════════════════════════════════════════════════════════════
//  BACKUP LOG — Historique des sauvegardes
// ═══════════════════════════════════════════════════════════════
model BackupLog {
  id        String   @id @default(cuid())
  path      String
  size      BigInt
  status    String   // SUCCESS, FAILED
  error     String?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("backup_logs")
}

// ═══════════════════════════════════════════════════════════════
//  SUBSCRIPTION — Gestion des abonnements
// ═══════════════════════════════════════════════════════════════
model Subscription {
  id            String   @id @default(cuid())
  organizationId String
  plan          String   // STARTER, PRO
  price         Int      // Prix annuel en DT
  paymentMethod String   // VIREMENT, ESPECES
  paymentStatus String   // PENDING, PAID, EXPIRED
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([paymentStatus])
  @@map("subscriptions")
}

// ═══════════════════════════════════════════════════════════════
//  SALES OBJECTIVE — Objectifs commerciaux par commercial
// ═══════════════════════════════════════════════════════════════
model SalesObjective {
  id            String   @id @default(cuid())
  organizationId String
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year          Int
  period        ObjectivePeriod @default(MONTHLY)
  month         Int?     // 1-12, null for quarterly/semi-annual/annual
  quarter       Int?     // 1-4, null for monthly/semi-annual/annual
  semester      Int?     // 1-2, null for monthly/quarterly/annual
  targetAmount  Decimal  @db.Decimal(12, 3) // Objectif en DT
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, year, period, month, quarter, semester])
  @@index([organizationId])
  @@index([userId])
  @@map("sales_objectives")
}

enum ObjectivePeriod {
  MONTHLY      // Mensuel
  QUARTERLY    // Trimestriel
  SEMI_ANNUAL  // Semestriel
  ANNUAL       // Annuel
}

// ═══════════════════════════════════════════════════════════════
//  USER PERMISSION — Permissions d'accès aux pages par utilisateur
// ═══════════════════════════════════════════════════════════════
model UserPermission {
  id            String   @id @default(cuid())
  organizationId String
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  page          String   // dashboard, affaires, clients, leads, calendar, expenses, activites, email-templates, ai-assistant, objectifs, settings
  canView       Boolean  @default(true)
  canCreate     Boolean  @default(false)
  canEdit       Boolean  @default(false)
  canDelete     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, page])
  @@index([organizationId])
  @@index([userId])
  @@map("user_permissions")
}

// ═══════════════════════════════════════════════════════════════
//  COMMISSION CONFIG — Configuration des primes commerciales
// ═══════════════════════════════════════════════════════════════
model CommissionConfig {
  id            String   @id @default(cuid())
  organizationId String   @unique
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Type de calcul
  calculationType CommissionType @default(SIMPLE)
  
  // Périodicité
  periodicity   CommissionPeriodicity @default(MONTHLY)
  
  // Configuration simple (pourcentage fixe)
  simpleRate    Decimal  @db.Decimal(5, 2) @default(0)
  
  // Configuration par paliers (JSON)
  tierConfig    String?  @db.Text // JSON: [{"min": 0, "max": 50, "rate": 0}, {"min": 50, "max": 80, "rate": 5}, ...]
  
  // Configuration progressive (JSON)
  progressiveConfig String? @db.Text // JSON: [{"min": 80, "max": 100, "multiplier": 1}, {"min": 100, "max": 110, "multiplier": 1.07}, ...]
  
  // Configuration personnalisée (formule)
  customFormula String?  @db.Text // Formule personnalisée
  
  // Paramètres additionnels
  minThreshold   Decimal  @db.Decimal(12, 3) @default(0) // Seuil minimum pour prime
  maxCap         Decimal? @db.Decimal(12, 3) // Plafond maximum
  
  // Configuration des types de ventes
  includeNewClients Boolean @default(true)
  includeRenewals Boolean @default(true)
  includeRecurring Boolean @default(true)
  
  // Délai de paiement (jours)
  paymentDelay  Int      @default(30) // Délai minimum de paiement client pour que la vente compte
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([organizationId])
  @@map("commission_configs")
}

enum CommissionType {
  SIMPLE       // Pourcentage fixe sur tout le CA
  TIERS        // Paliers par seuils d'atteinte
  PROGRESSIVE  // Progressif linéaire (votre exemple)
  CUSTOM       // Formule personnalisée
}

enum CommissionPeriodicity {
  MONTHLY      // Mensuel
  QUARTERLY    // Trimestriel
  SEMI_ANNUAL  // Semestriel
  ANNUAL       // Annuel
}
