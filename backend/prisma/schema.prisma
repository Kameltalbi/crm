// Prisma schema pour kt-Optima
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
//  ORGANIZATION — Tenant/Client pour le multitenant
// ═══════════════════════════════════════════════════════════════
model Organization {
  id          String   @id @default(cuid())
  name        String   // ex: "Bilan Tunisie"
  email       String?  // Email de contact de l'organisation
  phone       String?
  address     String?
  tva         String?  // Numéro TVA
  logoUrl     String?  // URL du logo
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  clients     Client[]
  affaires    Affaire[]
  products    Product[]
  activites   Activite[]
  emails      Email[]
  gmailTokens GmailToken[]
  previsionnels PrevisionMois[]
  notifications Notification[]

  @@map("organizations")
}

// ═══════════════════════════════════════════════════════════════
//  USER — Utilisateur du CRM
// ═══════════════════════════════════════════════════════════════
model User {
  id           String   @id @default(cuid())
  organizationId String
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientsCreated   Client[]
  affairesCreated  Affaire[]
  gmailTokens      GmailToken?
  notifications    Notification[]

  @@index([organizationId])
  @@map("users")
}

enum UserRole {
  OWNER   // Accès complet, gestion des utilisateurs
  PARTNER // Accès limité, lecture seule sur les données
}

// ═══════════════════════════════════════════════════════════════
//  CLIENT — Entreprises clientes
// ═══════════════════════════════════════════════════════════════
model Client {
  id          String   @id @default(cuid())
  organizationId String
  name        String   // ex: "UBCI"
  contactName String?  // ex: "Ahmed Ben Ali"
  email       String?
  phone       String?
  address     String?
  matricule   String?  // Matricule fiscal tunisien
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id])
  affaires    Affaire[]

  @@index([organizationId])
  @@index([name])
  @@map("clients")
}

// ═══════════════════════════════════════════════════════════════
//  AFFAIRE — Deal / Opportunité (cœur du CRM)
// ═══════════════════════════════════════════════════════════════
model Affaire {
  id            String        @id @default(cuid())
  organizationId String
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Détails prestation
  productId     String?
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  type          AffaireType
  title         String        // ex: "Bilan Carbone UBCI 2026"
  description   String?       @db.Text
  montantHT     Decimal       @db.Decimal(12, 3) // DT, 3 décimales
  
  // Pipeline
  statut        StatutAffaire @default(PROSPECTION)
  probabilite   Int           @default(50) // 0-100 %
  
  // Planning
  moisPrevu     Int           // 1-12
  anneePrevue   Int           // 2026, 2027, 2028
  dateClotureReelle DateTime?
  
  // Partenaire & commission
  viaPartenaire Boolean       @default(false)
  tauxCommission Decimal      @db.Decimal(5, 2) @default(40.00) // 40%
  
  // Liens vers Softfacture (quand devis/facture créés)
  devisId       String?       // ID retourné par Softfacture API
  devisNumero   String?
  devisPdfUrl   String?
  factureId     String?
  factureNumero String?
  facturePdfUrl String?
  
  // Méta
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdById   String?
  createdBy     User?         @relation(fields: [createdById], references: [id])

  // Relations
  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activites     Activite[]
  emails        Email[]

  @@index([organizationId])
  @@index([statut, anneePrevue])
  @@index([clientId])
  @@index([productId])
  @@map("affaires")
}

enum AffaireType {
  BILAN_CARBONE
  FORMATION
}

enum StatutAffaire {
  PROSPECTION  // 🟡 Premier contact, négociation
  PIPELINE     // 🔵 Offre envoyée, forte probabilité
  REALISE      // ✅ Gagné, livré/en cours
  PERDU        // ❌ Refusé ou abandonné
}

// ═══════════════════════════════════════════════════════════════
//  ACTIVITE — Historique des actions sur une affaire
// ═══════════════════════════════════════════════════════════════
model Activite {
  id        String        @id @default(cuid())
  organizationId String
  affaireId String
  affaire   Affaire       @relation(fields: [affaireId], references: [id], onDelete: Cascade)
  type      ActiviteType
  title     String
  content   String?       @db.Text
  createdAt DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([affaireId, createdAt])
  @@map("activites")
}

enum ActiviteType {
  NOTE
  APPEL
  EMAIL_ENVOYE
  EMAIL_RECU
  RDV
  CHANGEMENT_STATUT
  DEVIS_CREE
  FACTURE_CREEE
  AUTRE
}

// ═══════════════════════════════════════════════════════════════
//  EMAIL — Emails envoyés depuis le CRM via Gmail
// ═══════════════════════════════════════════════════════════════
model Email {
  id          String   @id @default(cuid())
  organizationId String
  affaireId   String?
  affaire     Affaire? @relation(fields: [affaireId], references: [id], onDelete: SetNull)
  messageId   String?  // ID Gmail
  fromEmail   String
  toEmail     String
  subject     String
  body        String   @db.Text
  sent        Boolean  @default(false)
  sentAt      DateTime?
  error       String?
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([affaireId])
  @@map("emails")
}

// ═══════════════════════════════════════════════════════════════
//  GMAIL TOKEN — OAuth tokens pour envoi d'emails
// ═══════════════════════════════════════════════════════════════
model GmailToken {
  id           String   @id @default(cuid())
  organizationId String
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  scope        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("gmail_tokens")
}

// ═══════════════════════════════════════════════════════════════
//  PREVISIONNEL — Hypothèses mensuelles paramétrables
// ═══════════════════════════════════════════════════════════════
model PrevisionMois {
  id               String  @id @default(cuid())
  organizationId    String
  annee            Int
  mois             Int     // 1-12
  nbBilansPrevu    Int     @default(0)
  prixMoyenBilan   Decimal @db.Decimal(12, 3) @default(0)
  joursFormation   Int     @default(0)
  tarifJourFormation Decimal @db.Decimal(12, 3) @default(0)
  estEte           Boolean @default(false)
  tauxPartenaire   Decimal @db.Decimal(5, 2) @default(0) // % d'affaires via partenaire
  notes            String?
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@unique([organizationId, annee, mois])
  @@map("prevision_mois")
}

// ═══════════════════════════════════════════════════════════════
//  PRODUCT — Produits/Services proposés
// ═══════════════════════════════════════════════════════════════
model Product {
  id          String   @id @default(cuid())
  organizationId String
  name        String   // ex: "Bilan Carbone Standard"
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 3) // Prix unitaire DT
  type        ProductType @default(SERVICE)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  affaires    Affaire[]

  @@index([organizationId])
  @@index([active])
  @@map("products")
}

// ═══════════════════════════════════════════════════════════════
//  NOTIFICATION — Notifications pour les utilisateurs
// ═══════════════════════════════════════════════════════════════
model Notification {
  id            String   @id @default(cuid())
  organizationId String
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          NotificationType
  title         String
  content       String?  @db.Text
  link          String?  // URL to navigate to when clicked
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId, read])
  @@map("notifications")
}

enum NotificationType {
  AFFAIRE_SANS_ACTIVITE  // Affaire sans activité depuis X jours
  TASK_OVERDUE           // Tâche en retard
  AFFAIRE_PERDUE         // Affaire perdue
  AFFAIRE_GAGNEE         // Affaire gagnée
  DEVIS_CREE             // Devis créé
  FACTURE_CREEE          // Facture créée
  RAPPEL                 // Rappel personnalisé
}

enum ProductType {
  SERVICE  // Bilan carbone, formation, conseil
  PRODUCT  // Produit physique
}
