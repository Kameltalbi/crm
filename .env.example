# ─── Backend ───────────────────────────────────────
DATABASE_URL="postgresql://bilan:bilan_pass@postgres:5432/bilan_crm?schema=public"
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
NODE_ENV="development"
PORT=4000
FRONTEND_URL="http://localhost:3000"

# ─── Softfacture API ───────────────────────────────
SOFTFACTURE_API_URL="https://api.softfacture.com"
SOFTFACTURE_API_KEY=""

# ─── Gmail (OAuth2) ────────────────────────────────
# Crée un projet sur https://console.cloud.google.com
# Active Gmail API, crée credentials OAuth2
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/gmail/callback"

# ─── PostgreSQL (docker-compose) ───────────────────
POSTGRES_USER="bilan"
POSTGRES_PASSWORD="bilan_pass"
POSTGRES_DB="bilan_crm"

# ─── Frontend ──────────────────────────────────────
VITE_API_URL="http://localhost:4000/api"

